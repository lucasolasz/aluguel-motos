# Template de variaveis do backend. Copie para .env e preencha os segredos:
#   cp .env.example .env   (Linux/Mac)   |   Copy-Item .env.example .env   (PowerShell)
# .env e lido nativamente pelo Spring (spring.config.import em application.properties).
# Sem default no application.properties => OBRIGATORIO aqui: DB_PASSWORD, JWT_SECRET, S3_ACCESS_KEY, S3_SECRET_KEY.

# ─── Banco ───
DB_URL=jdbc:postgresql://localhost:5432/postgres
DB_USER=
DB_PASSWORD=

# ─── Seguranca ───
JWT_SECRET=
CORS_ORIGINS=http://localhost:3000
# Chave de criptografia AES-256 dos campos sensiveis (CPF). NUNCA alterar apos usuarios existirem.
ENCRYPTION_KEY=

# ─── Storage S3 (Garage) ───
S3_ENDPOINT=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=
S3_PUBLIC_BASE_URL=

# Bypass de validacao de certificado TLS do storage.
# true SOMENTE em maquina de dev atras de proxy/MITM corporativo (ex: tribunal).
# Em casa e em producao: deixe false / nao defina.
S3_SSL_TRUST_ALL=false

# ─── Security ─────────────────────────────────────────────────────────────────
# HSTS (Strict-Transport-Security): true em producao (com HTTPS), false em dev.
SECURITY_HSTS_ENABLED=false

# Actuator endpoints expostos. Dev: health,info | Prod: health
ACTUATOR_EXPOSURE=health,info

# ─── Asaas (gateway de pagamento) ─────────────────────────────────────────────
ASAAS_BASE_URL=
ASAAS_API_KEY=

# Chave de criptografia AES-256 exclusiva para numeros de cartao. NUNCA alterar apos cartoes existirem.
CARD_ENCRYPTION_KEY=

