# Template de variaveis do backend. Copie para .env e preencha os segredos:
#   cp .env.example .env   (Linux/Mac)   |   Copy-Item .env.example .env   (PowerShell)
# .env e lido nativamente pelo Spring (spring.config.import em application.properties).
# Sem default no application.properties => OBRIGATORIO aqui: DB_PASSWORD, JWT_SECRET, S3_ACCESS_KEY, S3_SECRET_KEY.

# ─── Banco ───
DB_URL=jdbc:postgresql://localhost:5432/postgres
DB_USER=postgres
DB_PASSWORD=

# ─── Seguranca ───
JWT_SECRET=
CORS_ORIGINS=http://localhost:3000

# ─── Storage S3 (Garage) ───
S3_ENDPOINT=https://s3.ltech.app.br
S3_REGION=us-east-1
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=bucketaluguelmotos
S3_PUBLIC_BASE_URL=https://bucketaluguelmotos.ltech.app.br

# Bypass de validacao de certificado TLS do storage.
# true SOMENTE em maquina de dev atras de proxy/MITM corporativo (ex: tribunal).
# Em casa e em producao: deixe false / nao defina.
S3_SSL_TRUST_ALL=false

# ─── PagBank ──────────────────────────────────────────────────────────────────
# Sandbox: https://sandbox.api.pagseguro.com | Producao: https://api.pagseguro.com
PAGBANK_BASE_URL=https://sandbox.api.pagseguro.com
PAGBANK_TOKEN=
PAGBANK_WEBHOOK_SECRET=
PAGBANK_ENABLED=false

# ─── Encryption ───────────────────────────────────────────────────────────────
# Chave AES-256 para criptografar dados sensiveis em repouso (cpf, nome do cartao).
# Gere uma vez: openssl rand -base64 32
CARD_ENCRYPTION_KEY=
